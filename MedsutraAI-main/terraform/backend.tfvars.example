# Example Terraform backend configuration
# Copy this file to backend.tfvars and customize for your environment
# Initialize with: terraform init -backend-config=backend.tfvars

bucket         = "ai-cancer-detection-terraform-state"
key            = "production/vpc/terraform.tfstate"
region         = "ap-south-1"
encrypt        = true
dynamodb_table = "ai-cancer-detection-terraform-locks"
